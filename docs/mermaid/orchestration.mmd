graph LR
    %% Custom Styling
    classDef default fill:#2d3436,stroke:#dfe6e9,stroke-width:2px,color:#fff;
    
    subgraph L1 [Layer 1: Foundations]
        direction TB
        B1[build-glibc]
        B2[build-openssl]
        B3[build-cacerts]
        B4[build-gcc]
    end

    subgraph L2 [Layer 2: Assembly]
        direction TB
        A1[assemble-static]
        A2[assemble-base]
        A3[assemble-cc]
        A1 --> A2
        A2 --> A3
    end

    subgraph L3 [Layer 3: Runtimes]
        direction TB
        R1[assemble-php]
        R2[assemble-java]
        R3[assemble-python]
    end

    L1 --> L2
    L2 --> L3
    
    %% Apply Styles
    style L1 fill:#2d3436,stroke:#0984e3,stroke-width:2px,color:#fff
    style L2 fill:#2d3436,stroke:#00cec9,stroke-width:2px,color:#fff
    style L3 fill:#2d3436,stroke:#6c5ce7,stroke-width:2px,color:#fff
    
    linkStyle default stroke:#dfe6e9,stroke-width:2px;

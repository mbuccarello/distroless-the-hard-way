graph TD
    %% Custom Styling
    classDef default fill:#2d3436,stroke:#dfe6e9,stroke-width:2px,color:#fff;
    classDef layer fill:#636e72,stroke:#b2bec3,stroke-width:2px,color:#fff,stroke-dasharray: 5 5;
    
    subgraph L1 [Layer 1: Foundations]
        direction TB
        F1[glibc]
        F2[openssl]
        F3[cacerts]
        F4[tzdata]
        F5[gcc/libgomp]
    end

    subgraph L2 [Layer 2: Core Images]
        direction TB
        S[static] --> B[base]
        B --> C[cc]
    end

    subgraph L3 [Layer 3: Runtimes]
        direction LR
        S --> GO[Go-Static]
        B --> PHP[PHP]
        B --> PERL[Perl]
        B --> GOC[Go-Cgo]
        C --> JAVA[Java]
        C --> DOT[Dotnet]
        C --> PY[Python]
        C --> NODE[Node.js]
    end

    L1 -.-> L2
    L2 -.-> L3

    %% Apply Styles
    style L1 fill:#2d3436,stroke:#636e72,color:#fff
    style L2 fill:#2d3436,stroke:#636e72,color:#fff
    style L3 fill:#2d3436,stroke:#636e72,color:#fff
    
    linkStyle default stroke:#dfe6e9,stroke-width:2px;

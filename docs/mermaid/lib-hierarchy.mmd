graph TB
    %% Modern Design System
    classDef source fill:#6366f1,stroke:#4338ca,color:#fff,stroke-width:2px;
    classDef fedora fill:#fffbeb,stroke:#d97706,color:#92400e,stroke-width:2px,stroke-dasharray: 5 5;
    classDef image fill:#059669,stroke:#064e3b,color:#fff,stroke-width:2px;
    classDef legend fill:#f8fafc,stroke:#cbd5e1,color:#1e293b;

    %% Legend Section (Top Right Position)
    subgraph Legend ["&nbsp; Documentation Legend &nbsp;"]
        direction TB
        l1["✅ [SOURCE] Native Build (Hard Way)"]
        l2["⚠️ [FEDORA] RPM Extract (Roadmap)"]
    end
    class Legend legend;
    class l1 source;
    class l2 fedora;

    %% Foundations
    subgraph L1 ["Layer 1: Foundations"]
        direction TB
        glibc["✅ [SOURCE] glibc<br/>(libc.so.6)"]
        openssl["🔐 [SOURCE] openssl<br/>(libssl.so.3)"]
        zlib["🗜️ [SOURCE] zlib<br/>(libz.so.1)"]
    end

    %% Assembly
    subgraph L2 ["Layer 2: Core Assembly"]
        direction TB
        base["🚀 base image"]
        cc["🛠️ cc image"]
        cacert["⚠️ [FEDORA] ca-certificates"]
        
        base --> cc
        cacert -.-> base
    end

    %% Runtimes
    subgraph L3 ["Layer 3: Runtimes & Stacks"]
        direction LR
        
        subgraph Python ["Python 3.12"]
            py_bin["⚠️ [FEDORA] Python Interpreter"]
            py_libs["⚠️ [FEDORA] libffi, expat, readline,<br/>sqlite, gdbm, libdb"]
            py_libs -.-> py_bin
        end

        subgraph Dotnet [".NET 8.0"]
            dotnet_bin["✨ [BINARY] Runtime"]
            dotnet_libs["⚠️ [FEDORA] libicu, krb5-libs"]
            dotnet_libs -.-> dotnet_bin
        end

        subgraph PHP ["PHP 8.3"]
            php_bin["⚠️ [FEDORA] PHP Interpreter"]
            php_libs["⚠️ [FEDORA] libxml2, pcre2,<br/>libedit, ncurses"]
            php_libs -.-> php_bin
        end
    end

    %% Global Connections
    L1 --> base
    cc --> Python
    cc --> Dotnet
    cc --> PHP

    %% Applying Classes
    class glibc,openssl,zlib,libcpp,libgcc source;
    class cacert,py_bin,py_libs,dotnet_bin,dotnet_libs,php_bin,php_libs fedora;
    class base,cc image;

    %% Layout spacing
    L1 ~~~ Legend
    L2 ~~~ Legend

FROM ghcr.io/mbuccarello/base-fedora:latest as builder
RUN dnf install -y gcc make autoconf pkg-config

# Inject foundations
COPY --from=ghcr.io/mbuccarello/cc:latest / /artifacts/
COPY --from=ghcr.io/mbuccarello/foundation-libffi:latest / /artifacts/
COPY --from=ghcr.io/mbuccarello/foundation-readline:latest / /artifacts/
COPY --from=ghcr.io/mbuccarello/foundation-ncurses:latest / /artifacts/
COPY --from=ghcr.io/mbuccarello/foundation-bzip2:latest / /artifacts/
COPY --from=ghcr.io/mbuccarello/foundation-liblzma:latest / /artifacts/
COPY --from=ghcr.io/mbuccarello/foundation-sqlite:latest / /artifacts/
COPY --from=ghcr.io/mbuccarello/foundation-libxcrypt:latest / /artifacts/

WORKDIR /build
RUN curl -L -o python.tar.gz https://www.python.org/ftp/python/3.12.5/Python-3.12.5.tgz && tar -xzf python.tar.gz --strip-components=1

# Move artifacts to /usr inside artifacts
RUN mkdir -p /artifacts/usr/lib64 /artifacts/usr/include /artifacts/usr/lib && \
    cp -r /artifacts/lib64/* /artifacts/usr/lib64/ 2>/dev/null || true && \
    cp -r /artifacts/lib/* /artifacts/usr/lib/ 2>/dev/null || true && \
    cp -r /artifacts/include/* /artifacts/usr/include/ 2>/dev/null || true

ENV PKG_CONFIG_PATH=/artifacts/usr/lib64/pkgconfig:/artifacts/usr/lib/pkgconfig
ENV CPPFLAGS="-I/artifacts/usr/include"
ENV LDFLAGS="-L/artifacts/usr/lib64 -L/artifacts/usr/lib -Wl,-rpath,/usr/local/lib:/usr/lib64:/usr/lib"
ENV C_INCLUDE_PATH=/artifacts/usr/include
ENV LIBRARY_PATH=/artifacts/usr/lib64:/artifacts/usr/lib

RUN mkdir -p /rootfs && \
    ./configure --prefix=/usr/local --enable-optimizations --with-system-ffi --enable-shared && \
    make -j$(nproc) && \
    make install DESTDIR=/rootfs

FROM scratch
COPY --from=ghcr.io/mbuccarello/base:latest / /
COPY --from=ghcr.io/mbuccarello/foundation-libffi:latest /lib/. /usr/lib/
COPY --from=ghcr.io/mbuccarello/foundation-readline:latest /lib/. /usr/lib/
COPY --from=ghcr.io/mbuccarello/foundation-ncurses:latest /lib/. /usr/lib/
COPY --from=ghcr.io/mbuccarello/foundation-bzip2:latest /lib/. /usr/lib/
COPY --from=ghcr.io/mbuccarello/foundation-liblzma:latest /lib/. /usr/lib/
COPY --from=ghcr.io/mbuccarello/foundation-sqlite:latest /lib/. /usr/lib/
COPY --from=ghcr.io/mbuccarello/foundation-libxcrypt:latest /lib/. /usr/lib/
COPY --from=builder /rootfs/usr/local /usr/local/
ENV PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENTRYPOINT ["/usr/local/bin/python3"]
CMD ["--version"]
